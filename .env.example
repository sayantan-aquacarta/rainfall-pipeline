# Optional environment overrides. Copy to .env for local use (gitignored).
# All settings have sensible defaults; you only need this for non-standard setups.

# Override the source PDF URL (e.g., for testing against a local mirror)
# RAINFALL_PDF_URL=https://mausam.imd.gov.in/Rainfall/DISTRICT_RAINFALL_DISTRIBUTION_COUNTRY_INDIA_cd.pdf

# Override the data directory (default: ./data relative to repo root)
# RAINFALL_DATA_DIR=/var/data/rainfall
